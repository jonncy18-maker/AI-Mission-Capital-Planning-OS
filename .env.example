# Capital Planning OS — environment template
# Copy to `.env` and fill in. `.env` is gitignored; never commit a real key.

# Anthropic API key — used by src/lib/anthropic.js to generate the AI briefing.
# Phase 1: read directly in the browser via import.meta.env.VITE_ANTHROPIC_KEY.
# Before public launch: move this server-side behind a Netlify Functions proxy
# and remove the VITE_ prefix so it never ships to the client bundle.
VITE_ANTHROPIC_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model id for the briefing call.
VITE_ANTHROPIC_MODEL=claude-sonnet-4-20250514
